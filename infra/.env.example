# EvidenceLens shared environment file (example).
#
# Copy to `infra/.env` and fill in values. Never commit `.env`.
# Per-service env files live under each service dir (e.g. gateway/.env);
# this file is for the shared docker-compose stack only.

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=evidencelens
POSTGRES_USER=evidencelens
POSTGRES_PASSWORD=changeme-dev-only

# ---- NATS JetStream ----
NATS_URL=nats://nats:4222
NATS_STREAM=EVIDENCELENS

# ---- Redis (rate limit counters, agent prompt cache) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Meilisearch ----
MEILI_URL=http://meilisearch:7700
MEILI_KEY=changeme-master-key

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- Neo4j ----
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-dev-only

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=evidencelens-raw
R2_ENDPOINT=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# ---- GCP ----
GCP_PROJECT=evidencelens-prod
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-deploy-sa.json
PUBSUB_TOPIC_RAW_DOCS=raw-docs
PUBSUB_TOPIC_CLICKS=click-events
PUBSUB_TOPIC_CITATION_EDGES=citation-edges

# ---- Cloudflare ----
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
CF_KV_NAMESPACE_ID=

# ---- OpenTelemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# ---- Grafana Cloud (set in production only) ----
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_PASSWORD=
GRAFANA_TEMPO_URL=
GRAFANA_TEMPO_USER=
GRAFANA_TEMPO_PASSWORD=
GRAFANA_MIMIR_URL=
GRAFANA_MIMIR_USER=
GRAFANA_MIMIR_PASSWORD=

# ---- Sentry / PostHog (frontend only; set in frontend/.env.local) ----
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- API keys for upstream sources (improves rate limits) ----
NCBI_API_KEY=
NCBI_TOOL=evidencelens
NCBI_EMAIL=contact@example.com
OPENFDA_API_KEY=
CORE_API_KEY=
CROSSREF_USER_AGENT=EvidenceLens/0.1 (mailto:contact@example.com)
OPENALEX_USER_AGENT=EvidenceLens/0.1 (mailto:contact@example.com)
UNPAYWALL_EMAIL=contact@example.com

# ---- Embedder ----
EMBEDDER_GRPC_URL=embedder:50051
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_FALLBACK_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_FALLBACK_DIM=384

# ---- Scorer ----
SCORER_GRPC_URL=scorer:50052
LTR_MODEL_PATH=/models/ltr_v1.json

# ---- Gateway ----
GATEWAY_PORT=8080
GATEWAY_RATE_LIMIT_REST_PER_MIN=60
GATEWAY_RATE_LIMIT_LLM_PER_MIN=30
GATEWAY_WS_MAX_CONNECTIONS_PER_IP=10

# ---- Agent ----
AGENT_PORT=8081
AGENT_KEY_VALIDATION_CACHE_TTL_SEC=600
AGENT_PROMPT_PATH=/prompts/agent_system.md

# ---- MCP server ----
MCP_PORT=8082
MCP_PUBLIC_URL=http://localhost:8082
