{
  "name": "@evidencelens/contracts",
  "version": "1.0.0",
  "description": "Frozen inter-service contracts for EvidenceLens (Protobuf-derived TypeScript types + GraphQL SDL re-export).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./graphql": {
      "default": "./graphql.js"
    },
    "./events": {
      "types": "./evidencelens/v1/events.d.ts",
      "import": "./evidencelens/v1/events.js"
    },
    "./document": {
      "types": "./evidencelens/v1/document.d.ts",
      "import": "./evidencelens/v1/document.js"
    },
    "./scorer": {
      "types": "./evidencelens/v1/scorer.d.ts",
      "import": "./evidencelens/v1/scorer.js"
    },
    "./embedder": {
      "types": "./evidencelens/v1/embedder.d.ts",
      "import": "./evidencelens/v1/embedder.js"
    }
  },
  "files": [
    "evidencelens/",
    "*.js",
    "*.d.ts",
    "*.graphql",
    "README.md"
  ],
  "scripts": {
    "build": "echo 'Generated by buf; this script is a noop. Run `buf generate` from /proto.'"
  }
}
